generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id        String   @id @default(cuid())
  eventNo   Int
  eventName String
  heatNo    Int
  category  String
  status    String   @default("pending")
  lanes     Lane[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventNo, heatNo])
  @@index([status])
}

model Lane {
  id      String  @id @default(cuid())
  eventId String
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  lane    Int
  name    String
  region  String  @default("")   // 등급: S14, S7, 비장애 등
  team    String
  notes   String?                // 비고: 중등, 고등 등
  record  String?
  rank    Int?
  status  String?                // DNS | DQ | DSQ

  @@unique([eventId, lane])
}
